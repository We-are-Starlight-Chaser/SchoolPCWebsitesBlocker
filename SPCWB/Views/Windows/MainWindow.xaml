<ui:FluentWindow
  x:Class="SPCWB.Views.Windows.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:SPCWB.Views.Windows"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sys="clr-namespace:System;assembly=System.Runtime"
  xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:helpers="clr-namespace:SPCWB.Helpers"
  xmlns:tb="http://www.hardcodet.net/taskbar"
  Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
  Width="1100"
  Height="650"
  d:DataContext="{d:DesignInstance local:MainWindow,
                                     IsDesignTimeCreatable=True}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  ExtendsContentIntoTitleBar="True"
  WindowBackdropType="Mica"
  WindowCornerPreference="Round"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d" WindowStyle="None"
>
    <Window.Resources>
        <helpers:RedirectConventer x:Key="RedirectConverter"/>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <tb:TaskbarIcon ToolTipText="SPCWB - Running" IconSource="pack://application:,,,/Assets/wpfui-icon-256.png">
            <tb:TaskbarIcon.TrayPopup>
                <Border BorderThickness="3">
                    <Button Command="{Binding ViewModel.ShowWindowCommand}">Show MainWindow</Button>
                </Border>
            </tb:TaskbarIcon.TrayPopup>
        </tb:TaskbarIcon>
        <ui:TitleBar
      x:Name="TitleBar"
      Title="{Binding ViewModel.ApplicationTitle}"
      Grid.Row="0"
      CloseWindowByDoubleClickOnIcon="True"
    >
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/wpfui-icon-256.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <TabControl Grid.Row="1" x:Name="tab">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <Border Width="66" Height="66" CornerRadius="18"
                    Background="{DynamicResource AccentFillColorSecondaryBrush}">
                                <Image Source="pack://application:,,,/Assets/wpfui-icon-256.png" Width="42" Height="42"/>
                            </Border>
                            <TextBlock TextAlignment="Center" FontSize="22" FontWeight="Bold">School PC Websites Blocker</TextBlock>
                            <TextBlock TextAlignment="Center" FontSize="18" FontWeight="Thin">Produced by the WASC team</TextBlock>
                        </StackPanel>
                        <TextBlock FontSize="20" FontWeight="Medium" VerticalAlignment="Center" Grid.Row="1" HorizontalAlignment="Center">👋Hi there!What would you like to do today?</TextBlock>
                        <Separator Grid.Row="2" Margin="0,5,0,0"></Separator>
                        <Grid Grid.Row="3" Margin="0,10,0,0" >
                            <WrapPanel HorizontalAlignment="Center">
                                <Button Command="{Binding ViewModel.RedirectToPageCommand}" Margin="5">
                                    <Button.CommandParameter>
                                        <MultiBinding Converter="{StaticResource RedirectConverter}">
                                            <Binding ElementName="tab"/>
                                            <Binding>
                                                <Binding.Source>
                                                    <sys:Int32>1</sys:Int32>
                                                </Binding.Source>
                                            </Binding>
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="CloudOff24" Margin="0,0,15,0"></ui:SymbolIcon>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                Websites Blocker
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" FontWeight="SemiBold">
                Use regular expressions, wildcards,
                <LineBreak/>
                etc. to block any websites you want to block!
                                        </TextBlock>
                                    </Grid>
                                </Button>
                                <Button Command="{Binding ViewModel.RedirectToPageCommand}" Margin="5">
                                    <Button.CommandParameter>
                                        <MultiBinding Converter="{StaticResource RedirectConverter}">
                                            <Binding ElementName="tab"/>
                                            <Binding>
                                                <Binding.Source>
                                                    <sys:Int32>2</sys:Int32>
                                                </Binding.Source>
                                            </Binding>
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="QrCode24" Margin="0,0,15,0"></ui:SymbolIcon>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                    Websites Unblocker
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" FontWeight="SemiBold">
                Scan the QR code to unlock the block for 40 minutes, 
                <LineBreak/>
                then block again!
                                        </TextBlock>
                                    </Grid>
                                </Button>
                                <Button Command="{Binding ViewModel.RedirectToPageCommand}" Margin="5">
                                    <Button.CommandParameter>
                                        <MultiBinding Converter="{StaticResource RedirectConverter}">
                                            <Binding ElementName="tab"/>
                                            <Binding>
                                                <Binding.Source>
                                                    <sys:Int32>3</sys:Int32>
                                                </Binding.Source>
                                            </Binding>
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,15,0"></ui:SymbolIcon>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                    Browser usage time
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" FontWeight="SemiBold">
                Get the 24-hour usage duration of browsers
                <LineBreak/>
                like Microsoft Edge,Google Chrome, etc.!
                                        </TextBlock>
                                    </Grid>
                                </Button>
                                <Button Command="{Binding ViewModel.RedirectToPageCommand}" Margin="5">
                                    <Button.CommandParameter>
                                        <MultiBinding Converter="{StaticResource RedirectConverter}">
                                            <Binding ElementName="tab"/>
                                            <Binding>
                                                <Binding.Source>
                                                    <sys:Int32>4</sys:Int32>
                                                </Binding.Source>
                                            </Binding>
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,15,0"></ui:SymbolIcon>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                                                Settings
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" FontWeight="SemiBold">
                                            Change any available settings, 
                                            <LineBreak/>
                                            unless you are a student!
                                        </TextBlock>
                                    </Grid>
                                </Button>
                            </WrapPanel>
                        </Grid>

                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Websites Blocker">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="20" FontWeight="Bold" Grid.Row="0">Blocked List</TextBlock>
                    <Border Grid.Row="1" Margin="5" BorderThickness="5">
                    <ui:ListView ItemsSource="{Binding ViewModel.BlockerItems}" IsEnabled="{Binding ViewModel.CanChangeBlocker}">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="16" FontWeight="Medium" Text="{Binding Name}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding IsBlocked}" HorizontalAlignment="Right" Margin="0,0,5,0">Blocked</CheckBox>
                                </Grid>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                    </Border>
                </Grid>

            </TabItem>
            <TabItem Header="Websites Unblocker">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="5">
                        <Border Width="260" Height="260" Padding="5" BorderThickness="2">
                            <Image Source="{Binding ViewModel.QrSource}" Width="250" Height="250" IsEnabled="{Binding ViewModel.CanChangeBlocker,Converter={StaticResource InverseBooleanConverter}}"/>
                        </Border>
                        <Button Command="{Binding ViewModel.GetQrCodeCommand}" IsEnabled="{Binding ViewModel.CanChangeBlocker,Converter={StaticResource InverseBooleanConverter}}" HorizontalAlignment="Center" Margin="0,5,0,0">Get latest QR Code</Button>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Separator HorizontalAlignment="Left" VerticalAlignment="Stretch" Background="Gray" Width="2" Margin="10,0,0,0">
                            <Separator.LayoutTransform>
                                <RotateTransform Angle="90"/>
                            </Separator.LayoutTransform>
                        </Separator>
                        <StackPanel Orientation="Vertical" IsEnabled="{Binding ViewModel.CanChangeBlocker,Converter={StaticResource InverseBooleanConverter}}">
                        <TextBlock FontSize="18" FontWeight="Medium" VerticalAlignment="Top">
                            Tip: A QR code can only unlock 
                            <LineBreak/>
                            the screen for 40 minutes, 
                            <LineBreak/>
                            and it cannot be unlocked again 
                            <LineBreak/>
                            during this time.
                        </TextBlock>
                            <Separator/>
                            <TextBlock Text="Verification Code:" FontSize="18" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBox Text="{Binding ViewModel.InputedVerificationCode,Mode=OneWayToSource}"/>
                            <Button Command="{Binding ViewModel.VerifyTheVerificationCodeCommand}" HorizontalAlignment="Stretch">Verify</Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Settings">
                <Grid>
                    <Expander>
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/Assets/wpfui-icon-256.png" Width="22" Height="22" Grid.Column="0"/>
                                    <TextBlock Text="©2026 We Are Starlight Chaser,All rights reserved." FontSize="14" FontWeight="Bold" Grid.Column="1" Margin="5,0,0,0"/>
                            </Grid>
                        </Expander.Header>
                        <md:MarkdownViewer Markdown="{Binding ViewModel.MarkdownText,Mode=OneWay}"></md:MarkdownViewer>
                    </Expander>
                </Grid>
            </TabItem>
        </TabControl>
        <ContentPresenter x:Name="RootContentDialog" Grid.Row="0" />
  </Grid>
</ui:FluentWindow>
